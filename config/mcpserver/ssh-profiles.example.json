{
  "profiles": {
    "devbox": {
      "host": "devbox.example.internal",
      "port": 22,
      "username": "mcpbot",
      "privateKeyPath": "%USERPROFILE%/.ssh/id_ed25519",
      "passwordEnvironmentVariable": null,
      "privateKeyPassphraseEnvironmentVariable": "MCP_SSH_DEVBOX_KEY_PASSPHRASE",
      "hostKeySha256": "SHA256:REPLACE_WITH_PINNED_HOST_KEY_FINGERPRINT",
      "acceptUnknownHostKey": false,
      "workingDirectory": "/srv/app",
      "allowedCommands": [
        "dotnet",
        "git",
        "ls",
        "pwd",
        "whoami"
      ],
      "allowedRemotePathPrefixes": [
        "/srv/app",
        "/tmp/mcp"
      ],
      "allowSudoCommand": false,
      "allowAllCommands": false,
      "privileged": false,
      "allowedRoot": false
    }
  }
}
