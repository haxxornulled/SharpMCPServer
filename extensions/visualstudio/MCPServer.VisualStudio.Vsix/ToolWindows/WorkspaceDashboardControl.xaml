<UserControl x:Class="MCPServer.VisualStudio.Vsix.ToolWindows.WorkspaceDashboardControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Loaded="OnLoaded">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="MCPServer Workspace"
                       FontSize="18"
                       FontWeight="SemiBold" />
            <TextBlock Text="{Binding StatusMessage}"
                       Margin="0,4,0,0"
                       TextWrapping="Wrap" />
            <TextBlock Text="{Binding LastRefreshedText}"
                       Margin="0,4,0,0"
                       Opacity="0.75" />
        </StackPanel>

        <Border Grid.Row="1"
                Margin="0,16,0,0"
                Padding="12"
                BorderThickness="1"
                BorderBrush="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                CornerRadius="4">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="170" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <Label Content="Workspace root" Grid.Row="0" Grid.Column="0" Margin="0,0,12,8" VerticalAlignment="Center" />
                <TextBox Text="{Binding WorkspaceRoot}" Grid.Row="0" Grid.Column="1" Margin="0,0,0,8" IsReadOnly="True" />

                <Label Content="Root source" Grid.Row="1" Grid.Column="0" Margin="0,0,12,8" VerticalAlignment="Center" />
                <TextBox Text="{Binding WorkspaceRootSource}" Grid.Row="1" Grid.Column="1" Margin="0,0,0,8" IsReadOnly="True" />

                <Label Content="Solution path" Grid.Row="2" Grid.Column="0" Margin="0,0,12,8" VerticalAlignment="Center" />
                <TextBox Text="{Binding SolutionPath}" Grid.Row="2" Grid.Column="1" Margin="0,0,0,8" IsReadOnly="True" />

                <Label Content="Solution name" Grid.Row="3" Grid.Column="0" Margin="0,0,12,8" VerticalAlignment="Center" />
                <TextBox Text="{Binding SolutionName}" Grid.Row="3" Grid.Column="1" Margin="0,0,0,8" IsReadOnly="True" />

                <Label Content="Primary project" Grid.Row="4" Grid.Column="0" Margin="0,0,12,8" VerticalAlignment="Center" />
                <TextBox Text="{Binding PrimaryProjectPath}" Grid.Row="4" Grid.Column="1" Margin="0,0,0,8" IsReadOnly="True" />

                <Label Content="Configuration" Grid.Row="5" Grid.Column="0" Margin="0,0,12,8" VerticalAlignment="Center" />
                <TextBox Text="{Binding ActiveConfiguration}" Grid.Row="5" Grid.Column="1" Margin="0,0,0,8" IsReadOnly="True" />

                <Label Content="Platform" Grid.Row="6" Grid.Column="0" Margin="0,0,12,0" VerticalAlignment="Center" />
                <TextBox Text="{Binding ActivePlatform}" Grid.Row="6" Grid.Column="1" IsReadOnly="True" />
            </Grid>
        </Border>

        <Grid Grid.Row="3" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <Label Content="Projects:" Grid.Column="0" VerticalAlignment="Center" />
            <TextBox Text="{Binding ProjectCount}" Grid.Column="1" Margin="8,0,0,0" Width="72" IsReadOnly="True" />
            <Button Grid.Column="2" Content="Refresh" Command="{Binding RefreshCommand}" Margin="12,0,0,0" />
            <Button Grid.Column="4" Content="Open Chat Console" Command="{Binding OpenChatConsoleCommand}" HorizontalAlignment="Right" />
        </Grid>

        <Button Grid.Row="4"
                Content="Open MCP Host"
                Command="{Binding OpenHostCommand}"
                HorizontalAlignment="Right"
                Margin="0,16,0,0" />
    </Grid>
</UserControl>
