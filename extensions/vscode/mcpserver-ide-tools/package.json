{
  "name": "mcpserver-ide-tools",
  "displayName": "MCPServer IDE Tools",
  "description": "Launch the MCPServer chat console and workspace actions from VS Code using repository-owned workflows.",
  "version": "0.1.6",
  "publisher": "haxxornulled",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/haxxornulled/SharpMCPServer.git"
  },
  "homepage": "https://github.com/haxxornulled/SharpMCPServer/tree/main/extensions/vscode/mcpserver-ide-tools",
  "bugs": {
    "url": "https://github.com/haxxornulled/SharpMCPServer/issues"
  },
  "engines": {
    "vscode": "^1.97.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "mcp",
    "mcpserver",
    "debug",
    "workspace",
    "launch-profile"
  ],
  "activationEvents": [
    "onStartupFinished",
    "onCommand:mcpserver.openChatConsole",
    "onCommand:mcpserver.showWorkspaceRoot",
    "onCommand:mcpserver.copyWorkspaceRoot",
    "onCommand:mcpserver.openWorkspaceRootInExplorer",
    "onCommand:mcpserver.refreshMcpServerState",
    "onCommand:mcpserver.showWorkspaceActions",
    "onCommand:mcpserver.configureInferenceRouting",
    "onCommand:mcpserver.configureInferenceProviderModel",
    "onCommand:mcpserver.configureInferenceProviderPriority",
    "onCommand:mcpserver.configureInferenceProviderPerformance",
    "onCommand:mcpserver.configureInferenceProviderApiKey",
    "onView:mcpserver.workspace"
  ],
  "main": "./out/extension.js",
  "files": [
    "out/**",
    "resources/**",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "package.json"
  ],
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "mcpserver",
          "title": "MCPServer",
          "icon": "resources/mcpserver.svg"
        }
      ]
    },
    "views": {
      "mcpserver": [
        {
          "id": "mcpserver.workspace",
          "name": "Workspace Bubble"
        }
      ]
    },
    "commands": [
      {
        "command": "mcpserver.openChatConsole",
        "title": "MCPServer: Open Chat Console"
      },
      {
        "command": "mcpserver.showWorkspaceRoot",
        "title": "MCPServer: Show Workspace Root"
      },
      {
        "command": "mcpserver.copyWorkspaceRoot",
        "title": "MCPServer: Copy Workspace Root"
      },
      {
        "command": "mcpserver.openWorkspaceRootInExplorer",
        "title": "MCPServer: Open Workspace Root in Explorer"
      },
      {
        "command": "mcpserver.refreshMcpServerState",
        "title": "MCPServer: Refresh MCPServer State"
      },
      {
        "command": "mcpserver.showWorkspaceActions",
        "title": "MCPServer: Workspace Actions"
      },
      {
        "command": "mcpserver.configureInferenceProviderModel",
        "title": "MCPServer: Configure Inference Provider Model"
      },
      {
        "command": "mcpserver.configureInferenceRouting",
        "title": "MCPServer: Configure Inference Routing"
      },
      {
        "command": "mcpserver.configureInferenceProviderPriority",
        "title": "MCPServer: Configure Inference Provider Priority"
      },
      {
        "command": "mcpserver.configureInferenceProviderPerformance",
        "title": "MCPServer: Configure Inference Provider Performance"
      },
      {
        "command": "mcpserver.configureInferenceProviderApiKey",
        "title": "MCPServer: Configure Inference Provider API Key"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^20.19.0",
    "@types/vscode": "^1.97.0",
    "typescript": "^5.8.0"
  }
}
