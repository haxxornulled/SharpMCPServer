{
  "McpTools": {
    "Ssh": {
      "Enabled": true,
      "RequireExplicitProfileAllowlist": true,
      "AllowUnknownHostKeys": false,
      "AllowShellInterpreterInlineCommands": false,
      "TimeoutSeconds": 60,
      "MaxOutputChars": 20000,
      "AllowedCommands": [
        "cat",
        "dotnet",
        "echo",
        "git",
        "ls",
        "pwd",
        "uname",
        "whoami"
      ],
      "DeniedCommands": [
        "chmod",
        "chown",
        "dd",
        "fdisk",
        "mkfs",
        "mount",
        "nc",
        "netcat",
        "passwd",
        "reboot",
        "rm",
        "shutdown",
        "su",
        "sudo",
        "umount",
        "useradd",
        "userdel",
        "usermod"
      ]
    }
  }
}
