{
  "McpTools": {
    "Ssh": {
      "Enabled": true,
      "RequireExplicitProfileAllowlist": true,
      "AllowUnknownHostKeys": false,
      "AllowShellInterpreterInlineCommands": false,
      "TimeoutSeconds": 60,
      "MaxOutputChars": 20000,
      "AllowedCommands": [
        "cat",
        "dotnet",
        "echo",
        "git",
        "ls",
        "pwd",
        "uname",
        "whoami"
      ],
      "DeniedCommands": [
        "chmod",
        "chown",
        "dd",
        "fdisk",
        "mkfs",
        "mount",
        "nc",
        "netcat",
        "passwd",
        "reboot",
        "rm",
        "shutdown",
        "su",
        "sudo",
        "umount",
        "useradd",
        "userdel",
        "usermod"
      ]
    }
  },
  "AgentRouter": {
    "Sqlite": {
      "ConnectionString": "Data Source=agent-router.db;Cache=Shared",
      "EnsureCreatedOnUse": true
    }
  },
  "McpInference": {
    "Routing": {
      "DefaultStrategy": "PrimaryThenFallback",
      "MaxConcurrentRequestsPerProvider": 2,
      "MaxFanOutCandidates": 4
    },
    "Providers": {
      "lmstudio": {
        "Enabled": true,
        "BaseAddress": "http://127.0.0.1:1234/v1/",
        "Model": "local-model",
        "HttpClientName": "lmstudio"
      },
      "ollama": {
        "Enabled": true,
        "BaseAddress": "http://127.0.0.1:11434/v1/",
        "Model": "llama3.1",
        "HttpClientName": "ollama"
      },
      "anthropic": {
        "Enabled": false,
        "BaseAddress": "https://api.anthropic.com/v1/",
        "Model": "claude-3-5-sonnet-latest",
        "HttpClientName": "anthropic",
        "AnthropicVersion": "2023-06-01"
      }
    }
  },
  "McpWorkspace": {
    "ApprovalToken": "",
    "Sqlite": {
      "EnsureCreatedOnUse": true
    },
    "Roots": []
  },
  "McpTransport": {
    "Http": {
      "Enabled": true,
      "Port": 3011,
      "Path": "/mcp/",
      "BindLoopbackOnly": true,
      "SseRetryMilliseconds": 3000,
      "SseHeartbeatMilliseconds": 15000,
      "MaxSessionHistoryMessages": 256,
      "Authorization": {
        "Enabled": false,
        "AuthorizationServers": [],
        "RequiredScopes": [],
        "ScopesSupported": []
      }
    }
  }
}
